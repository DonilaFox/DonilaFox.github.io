d\u044b\u043c \u0440\u0430\u0431\u043e\u0442\u0430\u043c \u041e\u0431 \u0430\u0432\u0442\u043e\u0440\u0435 \u0418\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043e\u0431\u043e \u043c\u043d\u0435 \u0438 \u043c\u043e\u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b \u0421\u0430\u0439\u0442 \u0441\u043e\u0437\u0434\u0430\u043d \u0441 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c MkDocs | 2026","title":"\u041d\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u044f"},{"location":"about/","text":"\u0416\u043e\u0445\u043e\u0432 \u0414\u0430\u043d\u0438\u0438\u043b (DonilaFox) \u00b6 \u0421\u0442\u0443\u0434\u0435\u043d\u0442 \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u043a\u0443\u0440\u0441\u0430 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442\u0430 \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0418\u0422\u041c\u041e, \u0443\u0432\u043b\u0435\u0447\u0451\u043d\u043d\u044b\u0439 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u0438 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u043e\u043c \u0445\u043e\u043a\u043a\u0435\u044f. \ud83c\udf93 \u041e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u00b6 \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0418\u0422\u041c\u041e \u0411\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442 \u043f\u043e \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044e \u00ab\u041a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u043d\u044b\u0435 \u043d\u0430\u0443\u043a\u0438\u00bb \u0413\u043e\u0434\u044b \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f: 2025\u20132029 \ud83d\udcbb \u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u00b6 \u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u044f\u0437\u044b\u043a : Python \u0418\u0437\u0443\u0447\u0430\u044e : C++ (\u0431\u043e\u043b\u0435\u0435 3 \u043c\u0435\u0441\u044f\u0446\u0435\u0432) \u0422\u0435\u043a\u0443\u0449\u0438\u0435 \u0442\u0435\u043c\u044b : \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0432\u0438\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u043f\u0435\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445, \u043a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u0441\u043b\u043e\u0432\u043e global , \u043e\u0441\u043d\u043e\u0432\u044b \u041e\u041e\u041f \u0418\u043d\u0442\u0435\u0440\u0435\u0441\u044b : \u0430\u043b\u0433\u043e\u0440\u0438\u0442\u043c\u044b, \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0438\u043d\u0442\u0435\u043b\u043b\u0435\u043a\u0442, \u0432\u0435\u0431-\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430, \u0441\u0442\u0438\u043f\u0435\u043d\u0434\u0438\u044f \ud83c\udfd2 \u0425\u043e\u043a\u043a\u0435\u0439 \u00b6 \u0411\u043e\u043b\u044c\u0448\u043e\u0439 \u0444\u0430\u043d\u0430\u0442 \u0445\u043e\u043a\u043a\u0435\u044f \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430. \u041c\u043e\u044f \u043b\u044e\u0431\u0438\u043c\u0430\u044f \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u2014 \u00ab\u041b\u043e\u043a\u043e\u043c\u043e\u0442\u0438\u0432 \u042f\u0440\u043e\u0441\u043b\u0430\u0432\u043b\u044c\u00bb . \u0421\u043b\u0435\u0436\u0443 \u0437\u0430 \u043c\u0430\u0442\u0447\u0430\u043c\u0438 \u041a\u0425\u041b, \u0427\u0435\u043c\u043f\u0438\u043e\u043d\u0430\u0442\u0430\u043c\u0438 \u043c\u0438\u0440\u0430 \u0438 \u041e\u043b\u0438\u043c\u043f\u0438\u0439\u0441\u043a\u0438\u043c\u0438 \u0438\u0433\u0440\u0430\u043c\u0438. \u0412\u0435\u0440\u044e \u0432 \u0441\u0438\u043b\u0443 \u043a\u043e\u043c\u0430\u043d\u0434\u043d\u043e\u0433\u043e \u0434\u0443\u0445\u0430 \u0438 \u0436\u0435\u043b\u0435\u0437\u043d\u0443\u044e \u0432\u043e\u043b\u044e \u2014 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u043e\u0441\u043f\u0438\u0442\u044b\u0432\u0430\u0435\u0442 \u0445\u043e\u043a\u043a\u0435\u0439. \u00ab\u0422\u043e\u043b\u044c\u043a\u043e \u041b\u043e\u043a\u043e - \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u043e\u0431\u0435\u0434\u0430!\u00bb \ud83d\ude82 \u0424\u043e\u0442\u043e \u00b6 \u041a\u043e\u043d\u0442\u0430\u043a\u0442\u044b \u00b6 Telegram : @DaniilZhohov Email : zhohovd2007@gmail.com Discord : donilafox \ud83c\udf10 \u041e\u043d\u043b\u0430\u0439\u043d \u00b6 \u041d\u0438\u043a\u043d\u0435\u0439\u043c : DonilaFox \u042f\u0437\u044b\u043a \u043e\u0431\u0449\u0435\u043d\u0438\u044f : \u0420\u0443\u0441\u0441\u043a\u0438\u0439","title":"About Me"},{"location":"about/#donilafox","text":"\u0421\u0442\u0443\u0434\u0435\u043d\u0442 \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u043a\u0443\u0440\u0441\u0430 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442\u0430 \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0418\u0422\u041c\u041e, \u0443\u0432\u043b\u0435\u0447\u0451\u043d\u043d\u044b\u0439 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u0438 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u043e\u043c \u0445\u043e\u043a\u043a\u0435\u044f.","title":"\u0416\u043e\u0445\u043e\u0432 \u0414\u0430\u043d\u0438\u0438\u043b (DonilaFox)"},{"location":"about/#_1","text":"\u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0418\u0422\u041c\u041e \u0411\u0430\u043a\u0430\u043b\u0430\u0432\u0440\u0438\u0430\u0442 \u043f\u043e \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044e \u00ab\u041a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u043d\u044b\u0435 \u043d\u0430\u0443\u043a\u0438\u00bb \u0413\u043e\u0434\u044b \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f: 2025\u20132029","title":"\ud83c\udf93 \u041e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435"},{"location":"about/#_2","text":"\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u044f\u0437\u044b\u043a : Python \u0418\u0437\u0443\u0447\u0430\u044e : C++ (\u0431\u043e\u043b\u0435\u0435 3 \u043c\u